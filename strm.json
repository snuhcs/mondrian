{
    "draw_output": true,
    "draw_inference_result": true,
    "video_configs": [
        {
            "path": "/data/local/tmp/video/MTA/test_cam_3_1000_1450.mp4",
            "fps": 10
        }
    ],
    "inference_engine": {
        "model": "YOLO_V4",
        "runtime": "TFLITE",
        "use_tiny": false,
        "conf_threshold": 0.1,
        "iou_threshold": 0.5,
        "num_workers": 1,
        "input_sizes": [
            800
        ]
    },
    "log_internal": true,
    "roi_wise_inference": false,
    "full_frame_interval": 1,
    "buffer_size": 500,
    "latency_slo_ms": 6000,
    "roi_extractor": {
        "num_workers": 2,
        "extraction_resize_width": 640,
        "extraction_resize_height": 360,
        "min_roi_area": 5000,
        "roi_padding": 10,
        "optical_flow_roi_confidence_threshold": 0.1,
        "pd_filter_threshold": 0.5
    },
    "roi_resizer": {
        "resize_margin": 10,
        "resize_smoothing_factor": 0.1,
        "static_resize_target": 100,
        "probe_step_size": 5,
        "num_probe_steps": 1,
        "probe_reset_threshold": 10.0,
        "overlap_threshold": 0.8,
        "absolute_confidence_threshold": 0.3,
        "relative_confidence_threshold": 0.1
    },
    "patch_mixer": {
        "merge": true,
        "merge_threshold": 0.5,
        "n_way_mixing": true,
        "priority_mixing": true
    },
    "patch_reconstructor": {
        "frame_boxes_iou_threshold": 0.5,
        "overlap_threshold": 0.8
    }
}