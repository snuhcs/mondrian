{
    "video_configs": [
        {
            "path": "/data/local/tmp/video/MTA/test_cam_3.mp4",
            "frame_range": [1000, 1450],
            "fps": 0
        }
    ],
    "log_internal": true,
    "log_execution": true,
    "log_roi": true,
    "draw_output": false,
    "allow_interpolation": false,
    "full_frame_interval": 1,
    "full_frame_size": 768,
    "buffer_size": 500,
    "latency_slo_ms": 10000,
    "use_emulated_batch": true,
    "use_roi_wise_inference": false,
    "roi_size": 64,
    "roi_extractor": {
        "max_queue_size": 200,
        "num_workers": 2,
        "extraction_resize_width": 960,
        "extraction_resize_height": 540,
        "min_roi_area": 0,
        "eat_pd": false,
        "roi_padding": 10,
        "optical_flow_roi_confidence_threshold": 0.1,
        "pd_filter_threshold": 0.5,
        "pd_interval": 5,
        "merge": true,
        "merge_threshold": 0.5
    },
    "roi_resizer": {
        "train_data": "MTA",
        "resize_smoothing_factor": 0.1,
        "static_target_scale": 1.0,
        "probe_step_size": 0.05,
        "num_probe_steps": 1,
        "overlap_threshold": 0.8,
        "absolute_confidence_threshold": 0.3,
        "relative_confidence_threshold": 0.1
    },
    "inference_engine": {
        "draw_inference_result": true,
        "model": "YOLO_V5",
        "runtime": "TFLITE",
        "use_tiny": false,
        "conf_threshold": 0.1,
        "iou_threshold": 0.5,
        "profile_warmups": 5,
        "profile_runs": 5,
        "input_sizes": [
            768
        ],
        "devices" : [
            "GPU"
        ]
    },
    "patch_reconstructor": {
        "frame_boxes_iou_threshold": 0.5,
        "box_filter_overlap_threshold": 0.8,
        "id_mapping_iou_threshold": 0.1
    }
}
