{
    "log_internal": true,
    "dispatcher": {
        "max_queue_size": 2,
        "full_inference_interval": 4,
        "roi_padding": 10
    },
    "roi_extractor": {
        "extraction_resize_width": 640,
        "extraction_resize_height": 360,
        "min_roi_area": 5000,
        "optical_flow_roi_confidence_threshold": 0.1,
        "merge_threshold": 0.5,
        #"max_merged_roi_size": 832,
        "of_roi": true,
        "pd_roi": true,
        "merge_roi": true
    },
    "patch_mixer": {
        "packing": true,
        "max_packed_frames": 60,
        "latency_slo_ms": 5000
    },
    "patch_reconstructor": {
        "max_queue_size": 2,
        "frame_boxes_iou_threshold": 0.5,
        "overlap_threshold": 0.8
    }
}
